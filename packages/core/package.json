{
  "name": "@harness-engineering/core",
  "version": "0.31.0",
  "description": "Core library for Harness Engineering toolkit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./architecture/matchers": {
      "types": "./dist/architecture/matchers.d.ts",
      "import": "./dist/architecture/matchers.mjs",
      "require": "./dist/architecture/matchers.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/architecture/matchers.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/clean.mjs dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "bench": "vitest bench"
  },
  "keywords": [
    "harness",
    "engineering",
    "ai",
    "agents",
    "development"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Intense-Visions/harness-engineering.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Intense-Visions/harness-engineering/issues"
  },
  "homepage": "https://github.com/Intense-Visions/harness-engineering/tree/main/packages/core#readme",
  "dependencies": {
    "@harness-engineering/graph": "workspace:*",
    "@harness-engineering/types": "workspace:*",
    "@typescript-eslint/typescript-estree": "^8.29.0",
    "ejs": "^3.1.10",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.2.5",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "^0.24.7",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
