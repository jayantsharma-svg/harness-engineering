{
  "name": "@harness-engineering/cli",
  "version": "3.0.1",
  "description": "CLI for Harness Engineering toolkit",
  "type": "module",
  "bin": {
    "harness": "./dist/bin/harness.js",
    "harness-mcp": "./dist/bin/harness-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "node ../../scripts/clean.mjs dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@harness-engineering/core": "workspace:*",
    "@harness-engineering/dashboard": "workspace:*",
    "@harness-engineering/graph": "workspace:*",
    "@harness-engineering/linter-gen": "workspace:*",
    "@harness-engineering/orchestrator": "workspace:*",
    "@harness-engineering/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typescript-eslint/typescript-estree": "^8.29.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "minimatch": "^10.2.5",
    "semver": "^7.7.4",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "^0.24.7",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@harness-engineering/intelligence": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@harness-engineering/intelligence": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Intense-Visions/harness-engineering.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Intense-Visions/harness-engineering/issues"
  },
  "homepage": "https://github.com/Intense-Visions/harness-engineering/tree/main/packages/cli#readme"
}
