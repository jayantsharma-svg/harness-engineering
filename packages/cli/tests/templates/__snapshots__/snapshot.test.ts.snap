    "language": "go",
    "version": 1
  },
  "tooling": {
    "packageManager": "go",
    "linter": "golangci-lint",
    "formatter": "gofmt",
    "buildTool": "go",
    "testRunner": "go test"
  }
}",
  "main.go": "package main

import "fmt"

func main() {
	fmt.Println("Hello, world!")
}
",
}
`;

