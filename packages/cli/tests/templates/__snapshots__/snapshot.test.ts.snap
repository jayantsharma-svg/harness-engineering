  "eslint.config.mjs": "import harnessPlugin from '@harness-engineering/eslint-plugin';

export default [
  harnessPlugin.configs.recommended,
  {
    rules: {
      '@harness-engineering/no-circular-deps': 'error',
      '@harness-engineering/no-forbidden-imports': 'error',
      '@harness-engineering/no-layer-violation': 'error',
    },
  },
];
",
  "harness.config.json": "{
  "version": 1,
  "name": "snapshot-test",
  "layers": [
    {
      "name": "types",
      "pattern": "src/types/**",
      "allowedDependencies": []
    },
    {
      "name": "domain",
      "pattern": "src/domain/**",
      "allowedDependencies": [
        "types"
      ]
    },
    {
      "name": "services",
      "pattern": "src/services/**",
      "allowedDependencies": [
        "types",
        "domain"
      ]
    },
    {
      "name": "api",
      "pattern": "src/api/**",
      "allowedDependencies": [
        "types",
        "domain",
        "services"
      ]
    }
  ],
  "forbiddenImports": [
    {
      "from": "src/types/**",
      "disallow": [
        "src/services/**",
        "src/api/**"
      ],
      "message": "Types layer cannot import from services or API"
    }
  ],
  "boundaries": {
    "requireSchema": [
      "src/api/**"
    ]
  },
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "template": {
    "level": "intermediate",
    "version": 1
  }
}",
  "package.json": "{
