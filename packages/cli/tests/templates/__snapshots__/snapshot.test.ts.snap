exports[`template snapshots > vue overlay with basic level matches snapshot 1`] = `
{
  ".agnix.toml": "# agnix configuration — validates CLAUDE.md, hooks, skills, and agent configs.
# Reference: https://agent-sh.github.io/agnix/docs/configuration
#
# Harness runs this config via \`harness validate --agent-configs\` (hybrid mode):
#   - If the \`agnix\` binary is on PATH, harness shells out to it (385+ rules).
#   - Otherwise, harness runs a built-in fallback rule set covering the
#     highest-value checks (CLAUDE.md size, invalid hooks, unreachable skills).
# Install agnix for the full rule catalogue: \`cargo install agnix-cli\`.

target = "claude-code"
strict = false
max_files = 10000
locale = "en"

[rules]
disabled_rules = []
",
  ".gitignore": "node_modules/
dist/
.env
.env.local
*.log
coverage/
.turbo/
",
  "AGENTS.md": "# snapshot-test Knowledge Map

## About This Project

snapshot-test — A project using Harness Engineering practices (basic adoption level).

## Documentation

- Main docs: \`docs/\`
- Architecture decisions: \`docs/architecture.md\`

## Source Code

- Entry point: \`src/index.ts\`

## Architecture

See \`docs/architecture.md\` for architectural decisions.
",
  "docs/index.md": "# snapshot-test Documentation

Welcome to the snapshot-test documentation.

## Getting Started

1. Install dependencies: \`npm install\`
2. Run checks: \`npx harness validate\`
3. Start development

## Architecture

See [architecture.md](./architecture.md) for architectural decisions.
",
  "harness.config.json": "{
  "version": 1,
  "name": "snapshot-test",
  "layers": [
    {
      "name": "types",
      "pattern": "src/types/**",
      "allowedDependencies": []
    },
    {
      "name": "domain",
      "pattern": "src/domain/**",
      "allowedDependencies": [
        "types"
      ]
    },
    {
      "name": "services",
      "pattern": "src/services/**",
      "allowedDependencies": [
        "types",
        "domain"
      ]
    },
    {
      "name": "api",
      "pattern": "src/api/**",
      "allowedDependencies": [
        "types",
        "domain",
        "services"
      ]
    }
  ],
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "template": {
    "level": "basic",
    "version": 1
  }
}",
  "index.html": "<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Harness Engineering App</title>
  </head>
  <body>
    <div id="app"></div>
    <script type="module" src="/src/main.ts"></script>
  </body>
</html>
",
  "package.json": "{
  "name": "snapshot-test",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vue-tsc && vite build",
    "harness:validate": "harness validate",
    "harness:check-deps": "harness check-deps",
    "dev": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@harness-engineering/cli": "^0.1.0",
    "typescript": "^5.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "vite": "^5.0.0"
  }
}",
  "src/App.vue": "<template>
  <main>
    <h1>Welcome to your Harness Engineering project</h1>
  </main>
</template>

<script setup lang="ts"></script>
",
  "src/index.ts": "export {};
",
  "src/lib/.gitkeep": "",
  "src/main.ts": "import { createApp } from 'vue';
import App from './App.vue';

createApp(App).mount('#app');
",
  "tsconfig.json": "{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true
  },
  "include": ["src"]
}
",
  "vite.config.ts": "import { defineConfig } from 'vite';
import vue from '@vitejs/plugin-vue';

export default defineConfig({
  plugins: [vue()],
});
",
}
